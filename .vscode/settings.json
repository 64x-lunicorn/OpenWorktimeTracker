{
  "editor.formatOnSave": true,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.exclude": {
    "**/.DS_Store": true,
    "**/build": true,
    "**/DerivedData": true,
    "**/*.xcodeproj": true,
    "**/.build": true
  },
  "search.exclude": {
    "**/build": true,
    "**/DerivedData": true,
    "**/.build": true
  },
  "[swift]": {
    "editor.tabSize": 4,
    "editor.rulers": [140]
  },
  "yaml.schemas": {
    "https://raw.githubusercontent.com/yonaskolb/XcodeGen/master/Docs/ProjectSpec.json": "project.yml"
  }
}
